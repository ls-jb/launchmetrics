# ============================
# Banco de dados (Supabase Postgres)
# ============================
# Use a connection string do tipo "Session" do Supabase, prefixada com postgresql+asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:SUA-SENHA@db.xxxx.supabase.co:5432/postgres

# ============================
# Supabase Auth
# ============================
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_JWT_SECRET=cole-aqui-o-jwt-secret-do-painel-do-supabase
SUPABASE_SERVICE_KEY=cole-aqui-o-service-role-key-do-supabase

# ============================
# CORS — origins separadas por vírgula
# ============================
CORS_ORIGINS=http://localhost:5173

# ============================
# Ambiente: development | staging | production
# ============================
ENVIRONMENT=development
